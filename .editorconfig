# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

# Ignore the entire "third_party" directory.
[third_party/**]
ignore = true

# File used for git commit message editing.
[COMMIT_EDITMSG]
max_line_length = 72
